<?xml version="1.0" encoding="utf-8"?>
<!-- Android Auto Backup rules (API 31+) -->
<!-- Backs up AllySong settings to Google Drive so they survive factory reset -->
<data-extraction-rules>
    <cloud-backup>
        <include domain="sharedpref" path="allysong_settings.xml" />
    </cloud-backup>
    <device-transfer>
        <include domain="sharedpref" path="allysong_settings.xml" />
    </device-transfer>
</data-extraction-rules>
